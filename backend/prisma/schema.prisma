generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum LevelType {
  HSK1
  HSK2
  HSK3
  HSK4
  HSK5
  HSK6
  COMMUNICATION
}

enum Role {
  USER
  ADMIN
}

enum SubStatus {
  PENDING
  CONFIRMED
  REJECTED
}

enum SubscriptionPlan {
  TWO_MONTHS    @map("2months")
  SIX_MONTHS    @map("6months")
  TWELVE_MONTHS @map("12months")
}

model User {
  id                String    @id @default(cuid())
  username          String    @unique
  email             String?   @unique
  avatarUrl         String?
  phone             String?
  dateOfBirth       DateTime? @db.Date
  gender            String    @default("Nam")
  country           String    @default("Việt Nam")
  level             LevelType @default(HSK3)
  learningGoal      String    @default("Giao tiếp") @map("learning_goal")
  dailyTarget       Int       @default(20) @map("daily_target")
  passwordHash      String?   @map("password_hash")
  expPoints         Int       @default(0) @map("exp_points")
  isPremium         Boolean   @default(false) @map("is_premium")
  role              Role      @default(USER)
  subscriptionUntil DateTime?
  createdAt         DateTime  @default(now()) @map("created_at")

  accounts      Account[]
  sessions      Session[]
  progress      Progress[]
  subscriptions Subscription[]
}

model Level {
  id          String    @id @default(cuid())
  type        LevelType? @unique
  name        String
  slug        String    @unique
  description String?
  imageUrl    String?   @map("image_url")
  order       Int       @default(0)
  isPublished Boolean   @default(true) @map("is_published")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  lessons Lesson[]

  @@map("levels")
}

model Subscription {
  id              String           @id @default(cuid())
  userId          String
  planId          SubscriptionPlan
  amount          Int
  status          SubStatus        @default(PENDING)
  transferContent String
  startedAt       DateTime?
  expiresAt       DateTime?
  confirmedAt     DateTime?
  confirmedBy     String?
  createdAt       DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([planId])
  @@index([createdAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Lesson {
  id          String    @id @default(cuid())
  levelId     String    @map("level_id")
  levelType   LevelType @map("level_type")
  lessonOrder Int       @map("lesson_order")
  title       String
  slug        String
  description String?
  imageUrl    String?   @map("image_url")
  isFree      Boolean   @default(true) @map("is_free")
  isPublished Boolean   @default(true) @map("is_published")
  expReward   Int       @default(10) @map("exp_reward")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  level      Level        @relation(fields: [levelId], references: [id], onDelete: Cascade)
  vocabulary Vocabulary[]
  sentences  Sentence[]
  progress   Progress[]

  @@unique([levelId, slug])
  @@index([levelId])
}

model Vocabulary {
  id             String   @id @default(cuid())
  lessonId       String   @map("lesson_id")
  hanzi          String
  pinyin         String
  meaningVi      String   @map("meaning_vi")
  example        String?
  examplePinyin  String?  @map("example_pinyin")
  exampleMeaning String?  @map("example_meaning")
  audioUrl       String?  @map("audio_url")
  imageUrl       String?  @map("image_url")
  order          Int      @default(0)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  lesson   Lesson     @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  progress Progress[]

  @@index([lessonId])
}

model Sentence {
  id         String  @id @default(cuid())
  lessonId   String  @map("lesson_id")
  sentenceVi String  @map("sentence_vi")
  sentenceZh String  @map("sentence_zh")
  audioUrl   String? @map("audio_url")

  lesson   Lesson     @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  progress Progress[]
}

model Progress {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  lessonId   String   @map("lesson_id")
  vocabId    String?  @map("vocab_id")
  sentenceId String?  @map("sentence_id")
  status     String   @default("completed")
  expGained  Int      @default(0) @map("exp_gained")
  createdAt  DateTime @default(now()) @map("created_at")

  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson   Lesson      @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  vocab    Vocabulary? @relation(fields: [vocabId], references: [id], onDelete: SetNull)
  sentence Sentence?   @relation(fields: [sentenceId], references: [id])

  @@map("progress")
}
