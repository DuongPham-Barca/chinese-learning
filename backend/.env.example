# Production runtime: Supabase transaction pooler.
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@HOST:6543/postgres?pgbouncer=true"
# Local runtime and Prisma CLI: Supabase session pooler/direct connection.
DIRECT_URL="postgresql://postgres.PROJECT_REF:PASSWORD@HOST:5432/postgres"
JWT_SECRET="<openssl rand -base64 32>"
AUTH_GOOGLE_ID="<Google OAuth client ID>"
AUTH_GOOGLE_SECRET="<Google OAuth client secret>"
GOOGLE_REDIRECT_URI="http://localhost:4000/api/auth/google/callback"
FRONTEND_URL="http://localhost:3000"
COOKIE_SAME_SITE="Lax"

# Cloudflare R2 avatar storage. R2_PUBLIC_URL is the bucket's r2.dev or custom domain.
R2_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com"
R2_ACCESS_KEY="<R2 access key>"
R2_SECRET_KEY="<R2 secret key>"
R2_BUCKET="chinese-learning"
R2_PUBLIC_URL="https://<public-bucket-domain>"


#Bot telegram
TELEGRAM_BOT_TOKEN="<telegram-bot-token>"
TELEGRAM_ADMIN_CHAT_ID="<telegram-admin-chat-id>"

#email
SMTP_HOST="<email-host>"
SMTP_PORT="<email-port>"
SMTP_USER="<email-user>"
SMTP_PASS="<email-password>"
SMTP_FROM="<email-from-address>"